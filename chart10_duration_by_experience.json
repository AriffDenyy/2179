{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Average Session Duration by Experience Level",
    "subtitle": "Advanced gym-goers work out 75% longer than beginners. Data: Gym Members Exercise Tracking",
    "fontSize": 16, "subtitleFontSize": 12, "anchor": "start",
    "color": "#2c3e50", "subtitleColor": "#7f8c8d"
  },
  "width": 400, "height": 280,
  "data": {"url": "data/duration_by_experience.csv"},
  "layer": [
    {
      "mark": {"type": "rule", "strokeWidth": 2.5},
      "encoding": {
        "y": {
          "field": "experience", "type": "nominal",
          "sort": ["Beginner","Intermediate","Advanced"],
          "title": "Experience Level",
          "axis": {"labelFontSize": 13, "titleFontSize": 13}
        },
        "x": {
          "field": "avg_duration", "type": "quantitative",
          "title": "Average Session Duration (hours)",
          "scale": {"domain": [0, 2]},
          "axis": {"labelFontSize": 11, "titleFontSize": 13}
        },
        "x2": {"datum": 0},
        "color": {
          "field": "experience", "type": "nominal",
          "scale": {"domain": ["Beginner","Intermediate","Advanced"], "range": ["#3498db","#f39c12","#e74c3c"]},
          "legend": null
        }
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 120},
      "encoding": {
        "y": {
          "field": "experience", "type": "nominal",
          "sort": ["Beginner","Intermediate","Advanced"]
        },
        "x": {"field": "avg_duration", "type": "quantitative"},
        "color": {
          "field": "experience", "type": "nominal",
          "scale": {"domain": ["Beginner","Intermediate","Advanced"], "range": ["#3498db","#f39c12","#e74c3c"]},
          "legend": null
        },
        "tooltip": [
          {"field": "experience", "type": "nominal", "title": "Experience Level"},
          {"field": "avg_duration", "type": "quantitative", "title": "Avg Duration (hrs)", "format": ".2f"},
          {"field": "count", "type": "quantitative", "title": "Members"}
        ]
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 10, "fontSize": 12, "fontWeight": "bold"},
      "encoding": {
        "y": {
          "field": "experience", "type": "nominal",
          "sort": ["Beginner","Intermediate","Advanced"]
        },
        "x": {"field": "avg_duration", "type": "quantitative"},
        "text": {"field": "avg_duration", "type": "quantitative", "format": ".2f"},
        "color": {
          "field": "experience", "type": "nominal",
          "scale": {"domain": ["Beginner","Intermediate","Advanced"], "range": ["#3498db","#f39c12","#e74c3c"]}
        }
      }
    }
  ],
  "config": {"view": {"stroke": null}, "font": "Segoe UI, Arial, sans-serif", "background": "#fafafa"}
}
