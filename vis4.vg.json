{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Monthly Tourist Arrivals - Seasonality Patterns (2023 vs 2025)",
    "subtitle": "Each cell shows total arrivals for that month. Darker = more tourists. Data: Tourism Malaysia",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "anchor": "start",
    "color": "#2c3e50",
    "subtitleColor": "#7f8c8d"
  },
  "width": 600,
  "height": 220,
  "data": {"url": "data/monthly_heatmap.csv"},
  "mark": {"type": "rect", "cornerRadius": 3},
  "encoding": {
    "x": {
      "field": "month_num",
      "type": "ordinal",
      "title": "Month",
      "axis": {
        "labelExpr": "['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][datum.value - 1]",
        "labelFontSize": 12,
        "titleFontSize": 13
      }
    },
    "y": {
      "field": "year",
      "type": "ordinal",
      "title": "Year",
      "axis": {
        "labelFontSize": 13,
        "titleFontSize": 13
      }
    },
    "color": {
      "field": "arrivals",
      "type": "quantitative",
      "title": "Arrivals",
      "scale": {
        "scheme": "blues",
        "domain": [1000000, 3000000]
      },
      "legend": {
        "title": "Tourist Arrivals",
        "format": ".2s",
        "gradientLength": 200,
        "titleFontSize": 11
      }
    },
    "tooltip": [
      {"field": "year", "type": "ordinal", "title": "Year"},
      {"field": "month", "type": "nominal", "title": "Month"},
      {"field": "arrivals", "type": "quantitative", "title": "Arrivals", "format": ","}
    ]
  },
  "config": {
    "view": {"stroke": null},
    "font": "Segoe UI, Arial, sans-serif",
    "background": "#fafafa",
    "axis": {"grid": false}
  }
}