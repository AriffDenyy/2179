{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Where Do Malaysia's Tourists Come From? (2025)",
    "subtitle": "Total tourist arrivals by country of nationality. Data: Tourism Malaysia",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "anchor": "start",
    "color": "#2c3e50",
    "subtitleColor": "#7f8c8d"
  },
  "width": 800,
  "height": 450,
  "projection": {"type": "naturalEarth1"},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/datasets/geo-countries/master/data/countries.geojson",
        "format": {"type": "json", "property": "features"}
      },
      "transform": [
        {
          "lookup": "properties.name",
          "from": {
            "data": {"url": "data/tourist_by_country_2025.csv"},
            "key": "country",
            "fields": ["arrivals"]
          }
        }
      ],
      "mark": {"type": "geoshape", "stroke": "#fff", "strokeWidth": 0.3},
      "encoding": {
        "color": {
          "condition": {
            "test": "datum.arrivals != null",
            "field": "arrivals",
            "type": "quantitative",
            "title": "Arrivals (2025)",
            "scale": {
              "type": "log",
              "scheme": "blues",
              "domain": [50000, 10000000]
            },
            "legend": {
              "title": "Tourist Arrivals",
              "format": ".2s",
              "titleFontSize": 11,
              "gradientLength": 150
            }
          },
          "value": "#e8e8e8"
        },
        "tooltip": [
          {"field": "properties.name", "type": "nominal", "title": "Country"},
          {"field": "arrivals", "type": "quantitative", "title": "Arrivals (2025)", "format": ","}
        ]
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/datasets/geo-countries/master/data/countries.geojson",
        "format": {"type": "json", "property": "features"}
      },
      "transform": [
        {
          "lookup": "properties.name",
          "from": {
            "data": {"url": "data/tourist_by_country_2025.csv"},
            "key": "country",
            "fields": ["arrivals"]
          }
        },
        {"filter": "datum.arrivals > 1000000"}
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#f39c12",
        "strokeWidth": 1.5,
        "fill": null
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "font": "Segoe UI, Arial, sans-serif",
    "legend": {
      "orient": "bottom-right",
      "padding": 8,
      "cornerRadius": 4,
      "fillColor": "white",
      "strokeColor": "#ddd"
    }
  }
}