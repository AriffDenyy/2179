{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Top 10 Tourist Source Countries - 2025 vs 2019",
    "subtitle": "Comparing 2025 arrivals against pre-pandemic 2019 levels. Data: Tourism Malaysia",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "anchor": "start",
    "color": "#2c3e50",
    "subtitleColor": "#7f8c8d"
  },
  "width": 500,
  "height": 350,
  "data": {"url": "data/top10_countries.csv"},
  "transform": [
    {
      "aggregate": [{"op": "sum", "field": "arrivals", "as": "total"}],
      "groupby": ["country"]
    },
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "total", "order": "descending"}]
    },
    {
      "lookup": "country",
      "from": {
        "data": {"url": "data/top10_countries.csv"},
        "key": "country",
        "fields": ["arrivals", "year"]
      }
    }
  ],
  "layer": [
    {
      "mark": {"type": "bar"},
      "encoding": {
        "y": {
          "field": "country",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "arrivals",
            "op": "max",
            "order": "descending"
          },
          "axis": {"labelFontSize": 12}
        },
        "x": {
          "field": "arrivals",
          "type": "quantitative",
          "title": "Tourist Arrivals",
          "axis": {
            "format": ".2s",
            "labelFontSize": 11,
            "titleFontSize": 13
          }
        },
        "color": {
          "field": "year",
          "type": "nominal",
          "title": "Year",
          "scale": {
            "domain": ["2019", "2025"],
            "range": ["#aed6f1", "#1a5276"]
          },
          "legend": {
            "title": "Year",
            "titleFontSize": 11,
            "symbolSize": 120
          }
        },
        "xOffset": {
          "field": "year",
          "type": "nominal"
        },
        "tooltip": [
          {"field": "country", "type": "nominal", "title": "Country"},
          {"field": "year", "type": "nominal", "title": "Year"},
          {"field": "arrivals", "type": "quantitative", "title": "Arrivals", "format": ","}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "font": "Segoe UI, Arial, sans-serif",
    "background": "#fafafa",
    "bar": {"cornerRadiusEnd": 3}
  }
}