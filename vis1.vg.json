{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Foreign Tourist Entry Points in Malaysia (2020-2023)",
    "subtitle": "Bubble size represents total arrivals. Data: OpenDOSM",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "anchor": "start",
    "color": "#2c3e50",
    "subtitleColor": "#7f8c8d"
  },
  "width": 750,
  "height": 500,
  "projection": {
    "type": "mercator",
    "center": [109, 4],
    "scale": 1800
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/datasets/geo-countries/master/data/countries.geojson",
        "format": {"type": "json", "property": "features"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e8f4ea",
        "stroke": "#b2d8b2",
        "strokeWidth": 0.5
      },
      "encoding": {
        "tooltip": {"field": "properties.name", "type": "nominal"}
      }
    },
    {
      "data": {
        "url": "data/poe_totals.csv"
      },
      "mark": {
        "type": "circle",
        "opacity": 0.8,
        "stroke": "white",
        "strokeWidth": 0.8
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "size": {
          "field": "total_arrivals",
          "type": "quantitative",
          "title": "Total Arrivals",
          "scale": {"range": [30, 3000]},
          "legend": {
            "title": "Total Arrivals",
            "format": ".2s",
            "titleFontSize": 11
          }
        },
        "color": {
          "field": "type",
          "type": "nominal",
          "title": "Entry Type",
          "scale": {
            "domain": ["Air", "Land", "Sea"],
            "range": ["#3498db", "#e67e22", "#2ecc71"]
          },
          "legend": {
            "title": "Entry Type",
            "titleFontSize": 11,
            "symbolSize": 120
          }
        },
        "tooltip": [
          {"field": "poe", "type": "nominal", "title": "Point of Entry"},
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "type", "type": "nominal", "title": "Entry Type"},
          {"field": "total_arrivals", "type": "quantitative", "title": "Total Arrivals (2020-2023)", "format": ","}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "font": "Segoe UI, Arial, sans-serif",
    "legend": {
      "orient": "bottom-right",
      "padding": 8,
      "cornerRadius": 4,
      "fillColor": "white",
      "strokeColor": "#ddd"
    }
  }
}