{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Sports & Fitness Venues Across Malaysia",
    "subtitle": "Bubble size = traffic score, colour = category. Use controls to filter.",
    "fontSize": 16, "subtitleFontSize": 12, "anchor": "start",
    "color": "#2c3e50", "subtitleColor": "#7f8c8d"
  },
  "params": [
    {
      "name": "state_filter",
      "value": "All",
      "bind": {
        "input": "select",
        "options": ["All","Selangor","Kuala Lumpur","Johor","Perak","Kedah","Sarawak","Sabah","Negeri Sembilan","Pahang","Terengganu","Penang","Melaka","Kelantan","Putrajaya","Perlis"],
        "name": "Filter by State: "
      }
    },
    {
      "name": "min_traffic",
      "value": 0,
      "bind": {"input": "range", "min": 0, "max": 80, "step": 5, "name": "Min Traffic Score: "}
    },
    {
      "name": "zoom_level",
      "value": 1800,
      "bind": {
        "input": "range",
        "min": 800,
        "max": 50000,
        "step": 100,
        "name": "Zoom: "
      }
    },
    {
  "name": "center_to",
  "value": [109, 4],
  "bind": {
    "input": "select",
    "options": [
      [109, 4],
      [101.7, 3.1],
      [101.5, 3.4],
      [103.1, 2.1],
      [102.2, 2.7],
      [102.3, 2.2],
      [102.6, 3.6],
      [101.1, 4.7],
      [100.3, 5.4],
      [100.6, 6.2],
      [102.2, 5.1],
      [103.1, 4.8],
      [113.6, 2.1],
      [116.7, 5.9],
      [101.7, 2.9],
      [100.2, 6.4]
    ],
    "labels": [
      "All Malaysia",
      "Kuala Lumpur",
      "Selangor",
      "Johor",
      "Negeri Sembilan",
      "Melaka",
      "Pahang",
      "Perak",
      "Penang",
      "Kedah",
      "Kelantan",
      "Terengganu",
      "Sarawak",
      "Sabah",
      "Putrajaya",
      "Perlis"
    ],
    "name": "Map Centre: "
  }
}
  ],
  "width": 750, "height": 500,
  "projection": {
    "type": "mercator",
    "center": {"expr": "center_to"},
    "scale":  {"expr": "zoom_level"}
  },
  "layer": [
     {
      "data": {
        "url": "js/ne_10m_admin_1_states_provinces.json",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_1_states_provinces"
        }
      },
      "transform": [
        {"filter": "datum.properties.admin == 'Malaysia'"}
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#e8f4ea",
        "stroke": "#b2d8b2",
        "strokeWidth": 0.5
      },
      "encoding": {
        "tooltip": {"field": "properties.name", "type": "nominal", "title": "State"}
      }
    },
    {
      "data": {"url": "data/sports_venues.csv"},
      "transform": [
        {"filter": "state_filter == 'All' || datum.state == state_filter"},
        {"filter": "datum.traffic_score >= min_traffic"}
      ],
      "mark": {"type": "circle", "opacity": 0.7, "stroke": "white", "strokeWidth": 0.5},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude":  {"field": "lat", "type": "quantitative"},
        "size": {
          "field": "traffic_score", "type": "quantitative",
          "scale": {"range": [20, 800]},
          "legend": {"title": "Traffic Score", "titleFontSize": 11}
        },
        "color": {
          "field": "category", "type": "nominal",
          "scale": {"scheme": "tableau10"},
          "legend": {"title": "Category", "titleFontSize": 11}
        },
        "tooltip": [
          {"field": "name",          "type": "nominal",      "title": "Venue"},
          {"field": "category",      "type": "nominal",      "title": "Category"},
          {"field": "state",         "type": "nominal",      "title": "State"},
          {"field": "traffic_score", "type": "quantitative", "title": "Traffic Score", "format": ".1f"},
          {"field": "rating",        "type": "quantitative", "title": "Rating",        "format": ".1f"}
        ]
      }
    }
  ],
  "config": {
  "view": {"stroke": null},
  "font": "Segoe UI, Arial, sans-serif",
  "legend": {
    "orient": "right",
    "padding": 8,
    "cornerRadius": 4,
    "fillColor": "white",
    "strokeColor": "#ddd",
    "offset": 10
  }
}
}