{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Traffic Score vs Customer Rating by Venue",
    "subtitle": "Does popularity always mean quality? Filter by category and minimum rating.",
    "fontSize": 16, "subtitleFontSize": 12, "anchor": "start",
    "color": "#2c3e50", "subtitleColor": "#7f8c8d"
  },
  "params": [
    {
      "name": "category_select",
      "value": "All",
      "bind": {
        "input": "select",
        "options": ["All","Gyms & Studios","Fishing & Hunting","Recreation Centers","Other Outdoor & Lawn Sports","Golf & Driving Ranges","Team Sports & Fields","Badminton & Squash","Bowling","Spas","Swimming Pools & Beaches"],
        "name": "Filter by Category: "
      }
    },
    {
      "name": "min_rating",
      "value": 1,
      "bind": {"input": "range", "min": 1, "max": 5, "step": 0.5, "name": "Min Rating: "}
    }
  ],
  "width": 600, "height": 400,
  "data": {"url": "data/traffic_vs_rating.csv"},
  "transform": [
    {"filter": "category_select == 'All' || datum.category == category_select"},
    {"filter": "datum.rating >= min_rating"}
  ],
  "layer": [
    {
      "mark": {"type": "point", "filled": true, "opacity": 0.6, "size": 60},
      "encoding": {
        "x": {
          "field": "traffic_score", "type": "quantitative", "title": "Traffic Score (Popularity)",
          "axis": {"labelFontSize": 11, "titleFontSize": 13}
        },
        "y": {
          "field": "rating", "type": "quantitative", "title": "Customer Rating",
          "scale": {"domain": [2, 5.2]},
          "axis": {"labelFontSize": 11, "titleFontSize": 13}
        },
        "color": {
          "field": "category", "type": "nominal", "title": "Category",
          "scale": {"scheme": "tableau10"},
          "legend": {"title": "Category", "titleFontSize": 11, "orient": "right"}
        },
        "tooltip": [
          {"field": "name", "type": "nominal", "title": "Venue"},
          {"field": "category", "type": "nominal", "title": "Category"},
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "traffic_score", "type": "quantitative", "title": "Traffic Score", "format": ".1f"},
          {"field": "rating", "type": "quantitative", "title": "Rating", "format": ".1f"}
        ]
      }
    },
    {
      "mark": {"type": "line", "color": "#e74c3c", "strokeDash": [6,4], "strokeWidth": 1.5},
      "transform": [{"regression": "rating", "on": "traffic_score"}],
      "encoding": {
        "x": {"field": "traffic_score", "type": "quantitative"},
        "y": {"field": "rating", "type": "quantitative"}
      }
    }
  ],
  "config": {"view": {"stroke": null}, "font": "Segoe UI, Arial, sans-serif", "background": "#fafafa"}
}
