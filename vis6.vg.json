{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Tourist Growth vs Pre-Pandemic Levels (2025 vs 2019)",
    "subtitle": "% change in arrivals from 2019 to 2025. Data: Tourism Malaysia",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "anchor": "start",
    "color": "#2c3e50",
    "subtitleColor": "#7f8c8d"
  },
  "width": 550,
  "height": 480,
  "data": {"url": "data/growth_rate.csv"},
  "layer": [
    {
      "mark": {"type": "rule", "strokeWidth": 2},
      "encoding": {
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": {"field": "growth_pct", "order": "descending"},
          "title": null,
          "axis": {"labelFontSize": 12}
        },
        "x": {
          "field": "growth_pct",
          "type": "quantitative",
          "title": "Growth vs 2019 (%)",
          "axis": {
            "labelFontSize": 11,
            "titleFontSize": 13,
            "format": "+d",
            "gridDash": [3, 3]
          }
        },
        "x2": {"datum": 0},
        "color": {
          "condition": {"test": "datum.growth_pct >= 0", "value": "#27ae60"},
          "value": "#e74c3c"
        }
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 90},
      "encoding": {
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": {"field": "growth_pct", "order": "descending"}
        },
        "x": {"field": "growth_pct", "type": "quantitative"},
        "color": {
          "condition": {"test": "datum.growth_pct >= 0", "value": "#27ae60"},
          "value": "#e74c3c"
        },
        "tooltip": [
          {"field": "country", "type": "nominal", "title": "Country"},
          {"field": "growth_pct", "type": "quantitative", "title": "Growth vs 2019 (%)", "format": "+.1f"},
          {"field": "arrivals_2025", "type": "quantitative", "title": "2025 Arrivals", "format": ","},
          {"field": "arrivals_2019", "type": "quantitative", "title": "2019 Arrivals", "format": ","}
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#999",
        "strokeDash": [4, 4],
        "strokeWidth": 1
      },
      "encoding": {
        "x": {"datum": 0, "type": "quantitative"}
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "font": "Segoe UI, Arial, sans-serif",
    "background": "#fafafa"
  }
}